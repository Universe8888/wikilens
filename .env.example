# Copy to .env and fill in. .env is gitignored.
# Only needed when using remote LLM/embedding providers.
#
# OPENAI_API_KEY — used by `wikilens contradict --judge openai` (default) and
#   `wikilens gap --judge openai`. Install with: pip install -e '.[judge]'
#   Obtain at: https://platform.openai.com/api-keys
# ANTHROPIC_API_KEY — used by `wikilens contradict --judge claude` and
#   `wikilens gap --judge claude`.
#   Obtain at: https://console.anthropic.com/settings/keys

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
