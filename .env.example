# Copy to .env and fill in. .env is gitignored.
# Only needed when using remote LLM/embedding providers.
#
# ANTHROPIC_API_KEY — used by `wikilens contradict --judge claude` (P4).
#   Install with: pip install -e '.[judge]'
#   Obtain at:    https://console.anthropic.com/settings/keys
# OPENAI_API_KEY — reserved for future backends; unused in P1-P4.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
